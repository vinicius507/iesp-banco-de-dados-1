Table empregado {
  codigo integer [primary key]
  nome_empregado varchar(100) [not null]
}

Table departamento {
  codigo integer [primary key]
  nome_departamento varchar(50) [not null]
}

Table gerente {
  codigo integer [primary key]
  nome_gerente varchar(100) [not null]
}

Table projeto {
  codigo integer [primary key]
  nome_projeto varchar(100) [not null]
  data_inicio date
  data_fim date
  codigo_departamento integer [not null]
  codigo_gerente integer [not null]
}

Table empregado_projeto {
  codigo_empregado integer [not null]
  codigo_projeto integer [not null]
  horas_trabalhadas numeric(2)

  Indexes {
    (codigo_empregado, codigo_projeto) [pk]
  }
}

Ref: departamento.codigo < projeto.codigo_departamento
Ref: gerente.codigo < projeto.codigo_gerente
Ref: empregado.codigo < empregado_projeto.codigo_empregado
Ref: projeto.codigo < empregado_projeto.codigo_projeto
